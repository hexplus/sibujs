{
  "name": "sibujs-workspace",
  "private": true,
  "type": "module",
  "engines": { "node": ">=18.0.0" },
  "scripts": {
    "build": "pnpm -r --if-present run build",
    "test": "pnpm -r --if-present run test -- --run",
    "typecheck": "pnpm -r exec tsc --noEmit",
    "lint": "pnpm -r --if-present run lint",
    "bench": "pnpm --filter @sibujs/core run bench"
  },
  "packageManager": "pnpm@9.12.0",
  "devDependencies": {
    "@biomejs/biome": "2.4.7",
    "@playwright/test": "^1.61.1",
    "@types/node": "^25.5.0",
    "esbuild": "^0.25.0",
    "@vitest/coverage-v8": "^3.1.3",
    "@vitest/ui": "^3.1.3",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^26.1.0",
    "tsup": "^8.5.1",
    "typescript": "^5.8.3",
    "vitest": "^3.1.3"
  }
}
