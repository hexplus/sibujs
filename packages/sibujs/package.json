{
  "name": "sibujs",
  "version": "4.0.0-alpha.0",
  "description": "A lightweight, function-based frontend framework with fine-grained reactivity and direct DOM rendering — no Virtual DOM, no compiler, no magic. Components are plain functions and signals bind straight to the DOM, giving you full control with zero build step required.",
  "keywords": [
    "frontend",
    "framework",
    "reactive",
    "dom"
  ],
  "homepage": "https://github.com/hexplus/sibujs#readme",
  "bugs": {
    "url": "https://github.com/hexplus/sibujs/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hexplus/sibujs.git"
  },
  "license": "MIT",
  "author": "hexplus (https://github.com/hexplus)",
  "type": "module",
  "sideEffects": ["./dist/cdn.global.js"],
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "MIGRATION.md",
    "LICENSE"
  ],
  "scripts": {
    "lint": "biome check --max-diagnostics=500 src/ tests/",
    "lint:fix": "biome check --write src/ tests/",
    "format": "biome format --write src/ tests/",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:browser": "pnpm run build && playwright test",
    "test:browser:install": "playwright install chromium firefox webkit",
    "build": "tsup index.ts data.ts ui.ts ssr.ts plugins.ts build.ts testing.ts --dts --format esm,cjs --out-dir dist --clean && tsup cdn.ts --config tsup.cdn.config.ts --format iife --globalName Sibu --out-dir dist --no-dts --minify",
    "prepublishOnly": "pnpm run build"
  },
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": { "types": "./dist/index.d.ts", "default": "./dist/index.js" },
      "require": { "types": "./dist/index.d.cts", "default": "./dist/index.cjs" }
    },
    "./data": {
      "import": { "types": "./dist/data.d.ts", "default": "./dist/data.js" },
      "require": { "types": "./dist/data.d.cts", "default": "./dist/data.cjs" }
    },
    "./ui": {
      "import": { "types": "./dist/ui.d.ts", "default": "./dist/ui.js" },
      "require": { "types": "./dist/ui.d.cts", "default": "./dist/ui.cjs" }
    },
    "./ssr": {
      "import": { "types": "./dist/ssr.d.ts", "default": "./dist/ssr.js" },
      "require": { "types": "./dist/ssr.d.cts", "default": "./dist/ssr.cjs" }
    },
    "./plugins": {
      "import": { "types": "./dist/plugins.d.ts", "default": "./dist/plugins.js" },
      "require": { "types": "./dist/plugins.d.cts", "default": "./dist/plugins.cjs" }
    },
    "./build": {
      "import": { "types": "./dist/build.d.ts", "default": "./dist/build.js" },
      "require": { "types": "./dist/build.d.cts", "default": "./dist/build.cjs" }
    },
    "./testing": {
      "import": { "types": "./dist/testing.d.ts", "default": "./dist/testing.js" },
      "require": { "types": "./dist/testing.d.cts", "default": "./dist/testing.cjs" }
    },
    "./cdn": {
      "default": "./dist/cdn.global.js"
    }
  },
  "typesVersions": {
    "*": {
      "data": ["./dist/data.d.ts"],
      "ui": ["./dist/ui.d.ts"],
      "ssr": ["./dist/ssr.d.ts"],
      "plugins": ["./dist/plugins.d.ts"],
      "build": ["./dist/build.d.ts"],
      "testing": ["./dist/testing.d.ts"]
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "browserslist": [
    "Chrome >= 80",
    "Firefox >= 78",
    "Safari >= 14",
    "Edge >= 80"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@sibujs/core": "workspace:^"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.7",
    "@playwright/test": "^1.61.1",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^3.1.3",
    "@vitest/ui": "^3.1.3",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^26.1.0",
    "tsup": "^8.5.1",
    "typescript": "^5.8.3",
    "vitest": "^3.1.3"
  }
}
