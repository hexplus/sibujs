{
  "name": "sibujs",
  "version": "3.4.1",
  "description": "A lightweight, function-based frontend framework that combines the best of React, Svelte, and Vue — with zero VDOM and maximum simplicity. Designed for developers who want fine-grained reactivity and full control without compilation or magic.",
  "keywords": [
    "frontend",
    "framework",
    "reactive",
    "dom"
  ],
  "homepage": "https://github.com/hexplus/sibujs#readme",
  "bugs": {
    "url": "https://github.com/hexplus/sibujs/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hexplus/sibujs.git"
  },
  "license": "MIT",
  "author": "hexplus (https://github.com/hexplus)",
  "type": "module",
  "sideEffects": false,
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "lint": "biome check --max-diagnostics=500 src/ tests/",
    "lint:fix": "biome check --write src/ tests/",
    "format": "biome format --write src/ tests/",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:browser": "npm run build && playwright test",
    "test:browser:install": "playwright install chromium firefox webkit",
    "build": "tsup index.ts data.ts ui.ts ssr.ts plugins.ts build.ts testing.ts --dts --format esm,cjs --out-dir dist --clean && tsup cdn.ts --config tsup.cdn.config.ts --format iife --globalName Sibu --out-dir dist --no-dts --minify",
    "publish:npm": "node publish.mjs",
    "prepublishOnly": "npm run build"
  },
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./data": {
      "types": "./dist/data.d.ts",
      "import": "./dist/data.js",
      "require": "./dist/data.cjs"
    },
    "./ui": {
      "types": "./dist/ui.d.ts",
      "import": "./dist/ui.js",
      "require": "./dist/ui.cjs"
    },
    "./ssr": {
      "types": "./dist/ssr.d.ts",
      "import": "./dist/ssr.js",
      "require": "./dist/ssr.cjs"
    },
    "./plugins": {
      "types": "./dist/plugins.d.ts",
      "import": "./dist/plugins.js",
      "require": "./dist/plugins.cjs"
    },
    "./build": {
      "types": "./dist/build.d.ts",
      "import": "./dist/build.js",
      "require": "./dist/build.cjs"
    },
    "./testing": {
      "types": "./dist/testing.d.ts",
      "import": "./dist/testing.js",
      "require": "./dist/testing.cjs"
    },
    "./cdn": {
      "default": "./dist/cdn.global.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "browserslist": [
    "Chrome >= 80",
    "Firefox >= 78",
    "Safari >= 14",
    "Edge >= 80"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@sibujs/core": "workspace:*"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.7",
    "@playwright/test": "^1.61.1",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^3.1.3",
    "@vitest/ui": "^3.1.3",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^26.1.0",
    "tsup": "^8.5.1",
    "typescript": "^5.8.3",
    "vitest": "^3.1.3"
  }
}
