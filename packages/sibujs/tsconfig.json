{
    "extends": "../../tsconfig.base.json",
    "compilerOptions": {
      "target": "ES2020",
      "lib": ["ES2022", "DOM", "DOM.Iterable"],
      "module": "ESNext",
      "declaration": true,
      "emitDeclarationOnly": true,
      "outDir": "dist",
      "moduleResolution": "node",
      "esModuleInterop": true,
      "strict": true,
      "noUnusedLocals": true,
      "noUnusedParameters": true,
      "noFallthroughCasesInSwitch": true,
      "skipLibCheck": true
    },
    "include": [
      "src",
      "index.ts",
      "data.ts",
      "ui.ts",
      "ssr.ts",
      "plugins.ts",
      "build.ts",
      "testing.ts",
      "cdn.ts"
    ]
  }
  