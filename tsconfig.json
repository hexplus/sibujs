{
    "compilerOptions": {
      "target": "ES2020",
      "lib": ["ES2022", "DOM", "DOM.Iterable"],
      "module": "ESNext",
      "declaration": true,
      "emitDeclarationOnly": true,
      "outDir": "dist",
      "moduleResolution": "node",
      "esModuleInterop": true,
      "strict": true,
      "noUnusedLocals": true,
      "noUnusedParameters": true,
      "noFallthroughCasesInSwitch": true,
      "skipLibCheck": true,
      "types": ["vitest"]
    },
    "include": ["src", "index.ts"]
  }
  